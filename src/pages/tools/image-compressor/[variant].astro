---
import Layout from '../../../layouts/Layout.astro';
import ToolDirectory from '../../../components/ToolDirectory.astro';
import ImageCompressor from '../../../components/ImageCompressor';
import { allVariants, variantData } from '../../../data/compressor-variants';

export function getStaticPaths() {
  return allVariants.map((variant) => ({
    params: { variant: variant.slug },
    props: variantData[variant.slug],
  }));
}

const { format, title, description, faq } = Astro.props;
const isTargetSizeMode = Astro.params.variant === 'compress-to-100kb';

const pageUrl = `https://toolkitfree.net/tools/image-compressor/${Astro.params.variant}`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "description": description,
  "url": pageUrl,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolkitfree.net" },
    { "@type": "ListItem", "position": 2, "name": "Image Compressor", "item": "https://toolkitfree.net/tools/image-compressor" },
    { "@type": "ListItem", "position": 3, "name": title, "item": pageUrl },
  ]
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question", "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer },
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={pageUrl}
  structuredData={[structuredData, faqStructuredData, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>{title}</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        {description}
      </p>

      {isTargetSizeMode && (
        <div class="status" style="margin-bottom: 1rem;">
          <strong>Verified 100KB target mode.</strong> Results are labeled Target met only when the actual output Blob is 100KB or less; otherwise the closest result is clearly marked.
        </div>
      )}

      <ImageCompressor
        client:load
        defaultMode={isTargetSizeMode ? 'target' : 'quality'}
        defaultTargetKB={100}
        defaultFormat={format}
      />

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>Adjustable compression quality</li>
          <li>Max width scaling option</li>
          <li>Batch compression support</li>
          <li>Verified target-size status and actual Blob size</li>
          <li>Image pixels are processed locally</li>
          <li>Capacity depends on browser memory and Canvas limits</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {faq.map((item: { question: string; answer: string }) => (
          <div class="faq-item">
            <details>
              <summary class="faq-question">{item.question}</summary>
              <div class="faq-answer">{item.answer}</div>
            </details>
          </div>
        ))}
      </section>

      <ToolDirectory currentId="image-compressor" mode="related" />
    </div>

    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <ToolDirectory currentId="image-compressor" mode="sidebar" />
    </aside>
  </div>
</Layout>
