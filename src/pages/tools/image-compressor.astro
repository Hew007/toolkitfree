---
import Layout from '../../layouts/Layout.astro';
import ToolDirectory from '../../components/ToolDirectory.astro';
import ImageCompressor from '../../components/ImageCompressor';

const faqItems = [
  {
    question: 'How does image compression work?',
    answer:
      "Our compressor re-encodes your image at a lower quality setting using the browser's built-in Canvas API. For JPEG images, this reduces file size by adjusting the compression level. For PNG, it uses PNG encoding. Your images never leave your device.",
  },
  {
    question: "What's the difference between quality levels?",
    answer:
      'At 100% quality, there is virtually no visible difference from the original. At 80% (our default), most people cannot tell the difference, but file sizes drop significantly. Below 60%, you may start to see compression artifacts in photos.',
  },
  {
    question: 'Can I compress PNG images?',
    answer:
      'Yes, but PNG is a lossless format, so quality adjustment has no effect on PNG. You can reduce PNG file size by limiting the maximum width, which scales down the image dimensions.',
  },
  {
    question: 'How much can I reduce file size?',
    answer:
      'Typically 30-70% reduction for JPEG photos at 80% quality. Results vary depending on the original image content — photos with lots of detail compress less than simpler images.',
  },
  {
    question: 'Is there a batch compression limit?',
    answer:
      'There is no server-side batch quota, but the practical limit depends on available browser memory and image dimensions. Large batches can be slow or fail, especially on mobile devices.',
  },
  {
    question: 'Can I download all compressed images at once?',
    answer:
      'Yes. After processing, Download all as ZIP creates one local archive containing only successful results. Individual downloads remain available, and any failed file stays visible with its error reason.',
  },
  {
    question: 'Will compression affect image dimensions?',
    answer:
      'No, unless you set a Max Width limit. By default, compression only affects file quality, not dimensions. If you set a Max Width, images wider than that limit will be scaled down proportionally.',
  },
  {
    question: 'How do I make a photo smaller to email?',
    answer:
      'Upload your photo, set quality to 75-80%, set max width to 1280px, and click Compress. Most phone photos (3-8MB) will compress to under 500KB — small enough for any email provider.',
  },
  {
    question: 'How do I reduce image file size to under 100KB?',
    answer:
      'Choose Target file size mode and enter 100KB. The tool uses bounded quality and dimension search, then labels each result Target met only when its actual Blob is 100KB or less.',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Free Image Compressor',
  description:
    'Compress images online to reduce file size while maintaining quality. Supports JPG, PNG, and WebP. Batch compression. 100% client-side.',
  url: 'https://toolkitfree.net/tools/image-compressor',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toolkitfree.net' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Image Compressor',
      item: 'https://toolkitfree.net/tools/image-compressor',
    },
  ],
};

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Layout
  title="Free Image Compressor - Reduce File Size Online"
  description="Compress images online to reduce file size while maintaining quality. Reduce JPG, PNG, WebP photos. Batch support. Adjustable quality. 100% free, no upload needed."
  structuredData={[structuredData, faqStructuredData, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>Free Online Image Compressor</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Reduce image file size while maintaining quality. Adjustable compression level and batch
        support. All processing in your browser — your files never leave your device.
      </p>

      <ImageCompressor client:load />

      <section class="howto-section">
        <h2>How to Compress Images</h2>
        <ol class="howto-steps">
          <li>Upload one or more images (JPG, PNG, WebP)</li>
          <li>Adjust the quality slider — 80% is a good starting point</li>
          <li>Optionally set a maximum width to reduce dimensions</li>
          <li>Click "Compress", then download files individually or once as a ZIP</li>
        </ol>
      </section>

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>Adjustable quality from 10% to 100%</li>
          <li>Quality mode or verified target-size mode</li>
          <li>Optional starting max width</li>
          <li>Batch compress with one ZIP download</li>
          <li>Shows before/after file sizes</li>
          <li>100% client-side processing</li>
          <li>Capacity depends on browser memory and Canvas limits</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {
          faqItems.map((item) => (
            <div class="faq-item">
              <details>
                <summary class="faq-question">{item.question}</summary>
                <div class="faq-answer">{item.answer}</div>
              </details>
            </div>
          ))
        }
      </section>

      <ToolDirectory currentId="image-compressor" mode="related" />
    </div>

    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <ToolDirectory currentId="image-compressor" mode="sidebar" />
    </aside>
  </div>
</Layout>
