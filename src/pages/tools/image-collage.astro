---
import Layout from '../../layouts/Layout.astro';
import ToolDirectory from '../../components/ToolDirectory.astro';
import ImageCollage from '../../components/ImageCollage';
import { getTool, toPublicUrl } from '../../data/tool-registry';

const tool = getTool('image-collage');
const toolUrl = toPublicUrl(tool.href);
const faqItems = [
  {
    question: 'How does the image collage maker work?',
    answer:
      'Upload multiple JPG, PNG, or WebP images, choose a layout, and the browser draws them onto one canvas. The final collage is exported locally as PNG, JPG, or WebP.',
  },
  {
    question: 'Are my images uploaded to ToolkitFree?',
    answer:
      'No. The images are decoded, arranged, previewed, and exported in your browser. ToolkitFree does not receive your files.',
  },
  {
    question: 'Can I stitch screenshots vertically?',
    answer:
      'Yes. Choose the Vertical stitch layout to combine screenshots or long comparisons from top to bottom.',
  },
  {
    question: 'Can I combine images side by side?',
    answer:
      'Yes. Choose Horizontal stitch to place images left to right, or use a grid when you have more than two images.',
  },
  {
    question: 'What is the difference between contain and cover?',
    answer:
      'Contain keeps every image fully visible inside its tile. Cover fills the tile and may crop edges. Original size keeps the source dimensions where possible.',
  },
  {
    question: 'Can I change the spacing and background?',
    answer:
      'Yes. You can adjust the gap, outer margin, corner radius, and background color before downloading the collage.',
  },
  {
    question: 'Which output formats are supported?',
    answer:
      'You can export the finished collage as PNG, JPG, or WebP. JPG and WebP include a quality setting.',
  },
  {
    question: 'Is there a file size limit?',
    answer:
      'The tool reviews image count, file size, pixels, and estimated memory before processing. Very large batches may be blocked to protect your browser.',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Free Image Collage Maker',
  description: tool.description,
  url: toolUrl,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: toPublicUrl('/') },
    { '@type': 'ListItem', position: 2, name: tool.name, item: toolUrl },
  ],
};

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Layout
  title="Free Image Collage Maker - Combine Photos Online"
  description="Combine images into a grid, side-by-side layout, or vertical stitch. Make a photo collage locally in your browser and download PNG, JPG, or WebP."
  structuredData={[structuredData, faqStructuredData, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>Free Online Image Collage Maker</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Combine screenshots, photos, product images, or comparison pictures into one clean collage.
        Upload your images, pick a simple layout, and download. Auto layout handles the arrangement
        for you, while optional controls remain available when you need them.
      </p>

      <ImageCollage client:load />

      <section class="howto-section">
        <h2>How to Make an Image Collage</h2>
        <ol class="howto-steps">
          <li>Upload two or more JPG, PNG, or WebP images</li>
          <li>Keep the recommended Auto layout or choose Grid, Side by side, or Vertical stitch</li>
          <li>Download the collage, or open Advanced options for precise sizing and appearance</li>
        </ol>
      </section>

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>Combine multiple images into one local canvas</li>
          <li>Recommended automatic layout with clear visual layout choices</li>
          <li>Fast upload → choose layout → download workflow</li>
          <li>Contain, cover, and original-size fit modes</li>
          <li>Optional advanced gap, margin, background, size, and corner controls</li>
          <li>Move images up or down to control the order</li>
          <li>PNG, JPG, and WebP export with quality control where supported</li>
          <li>100% client-side processing with no file upload</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {
          faqItems.map((item) => (
            <div class="faq-item">
              <details>
                <summary class="faq-question">{item.question}</summary>
                <div class="faq-answer">{item.answer}</div>
              </details>
            </div>
          ))
        }
      </section>

      <ToolDirectory currentId="image-collage" mode="related" />
    </div>

    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <ToolDirectory currentId="image-collage" mode="sidebar" />
    </aside>
  </div>
</Layout>
