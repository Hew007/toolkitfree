---
import Layout from '../../layouts/Layout.astro';
import ImageResizer from '../../components/ImageResizer';

const faqItems = [
  {
    question: 'How do I resize an image?',
    answer: 'Upload your image, select a preset size or enter custom dimensions, choose the output format, and click Resize. The resized image will be ready to download instantly.',
  },
  {
    question: 'What presets are available?',
    answer: 'We offer presets for Instagram Post, Instagram Story, Facebook Cover, Twitter/X Header, YouTube Thumbnail, Full HD, HD, and Thumbnail sizes.',
  },
  {
    question: 'What does "maintain aspect ratio" do?',
    answer: 'When enabled, the tool automatically adjusts one dimension to match the original image\'s proportions. This prevents your image from appearing stretched or squished.',
  },
  {
    question: 'Can I resize multiple images at once?',
    answer: 'Yes, you can upload and resize multiple images simultaneously. All images will be resized to the same dimensions.',
  },
  {
    question: 'What output formats are supported?',
    answer: 'You can save resized images as JPG, PNG, or WebP. JPG is best for photos, PNG for graphics with transparency, and WebP for the best compression.',
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free Image Resizer",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0" },
};
---

<Layout
  title="Free Image Resizer - Resize Images Online to Any Size"
  description="Resize images online to any dimension. Presets for Instagram, Facebook, Twitter, YouTube. Batch resize. Free, no upload needed."
  structuredData={[structuredData, {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question", "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer },
    })),
  }]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>Free Online Image Resizer</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Resize images to any dimension. Presets for social media. Aspect ratio lock. Batch support.
        All processing in your browser.
      </p>

      <ImageResizer client:load />

      <section class="howto-section">
        <h2>How to Resize Images</h2>
        <ol class="howto-steps">
          <li>Upload one or more images</li>
          <li>Choose a preset or enter custom width and height</li>
          <li>Select output format and quality</li>
          <li>Click "Resize" and download your images</li>
        </ol>
      </section>

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>Presets for Instagram, Facebook, Twitter, YouTube</li>
          <li>Custom width and height</li>
          <li>Maintain aspect ratio option</li>
          <li>Output as JPG, PNG, or WebP</li>
          <li>Batch resize support</li>
          <li>100% client-side processing</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {faqItems.map((item) => (
          <div class="faq-item">
            <details>
              <summary class="faq-question">{item.question}</summary>
              <div class="faq-answer">{item.answer}</div>
            </details>
          </div>
        ))}
      </section>

      <section class="related-tools">
        <h2>Related Tools</h2>
        <div class="related-tools-grid">
          <a href="/tools/image-converter" class="tool-card"><h3>Image Converter</h3><p>Convert between JPG, PNG, and WebP</p></a>
          <a href="/tools/image-compressor" class="tool-card"><h3>Image Compressor</h3><p>Reduce image file size</p></a>
          <a href="/tools/background-remover" class="tool-card"><h3>Background Remover</h3><p>Remove backgrounds using AI</p></a>
        </div>
      </section>
    </div>
    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <div style="margin-top: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">More Tools</h3>
        <ul style="font-size: 0.875rem; list-style: none;">
          <li style="padding: 0.25rem 0;"><a href="/tools/image-converter">Image Converter</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-compressor">Image Compressor</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/background-remover">Background Remover</a></li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>
