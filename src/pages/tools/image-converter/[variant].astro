---
import Layout from '../../../layouts/Layout.astro';
import ImageConverter from '../../../components/ImageConverter';
import { allVariants, faqData, descriptions } from '../../../data/converter-variants';

export function getStaticPaths() {
  return allVariants.map((v) => ({
    params: { variant: v.slug },
    props: { ...v, faq: faqData[v.slug], description: descriptions[v.slug], title: ['heic-to-jpg', 'tiff-to-jpg', 'png-to-gif'].includes(v.slug) ? `${v.from} to ${v.to} - Current Support Status` : `Convert ${v.from} to ${v.to} Online Free` },
  }));
}

const { from, to, title, description, faq, slug } = Astro.props;

const unsupportedReasons: Record<string, string> = {
  'heic-to-jpg': 'HEIC decoding is not implemented yet. The current converter relies on the browser built-in decoder, which does not reliably open HEIC files.',
  'tiff-to-jpg': 'TIFF decoding is not implemented yet. The current converter cannot reliably open TIFF files in modern browsers.',
  'png-to-gif': 'GIF output is not implemented yet. The current converter can export only JPG, PNG, and WebP files.',
};
const browserDependentNotes: Record<string, string> = {
  'gif-to-png': 'GIF input depends on your browser. When it opens successfully, only one static frame is exported; animation is not preserved.',
  'bmp-to-png': 'BMP input depends on your browser built-in decoder and is not guaranteed on every device.',
  'svg-to-png': 'SVG input depends on your browser. External SVG resources may not render, and output uses the decoded dimensions.',
};
const unsupportedReason = unsupportedReasons[slug];
const browserDependentNote = browserDependentNotes[slug];
const isLimitedVariant = Boolean(unsupportedReason || browserDependentNote);

const pageUrl = `https://toolkitfree.net/tools/image-converter/${Astro.params.variant}`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0" },
  "url": pageUrl,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolkitfree.net" },
    { "@type": "ListItem", "position": 2, "name": "Image Converter", "item": "https://toolkitfree.net/tools/image-converter" },
    { "@type": "ListItem", "position": 3, "name": `${from} to ${to}`, "item": pageUrl },
  ]
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer },
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={pageUrl}
  structuredData={unsupportedReason ? [faqStructuredData, breadcrumbSchema] : [structuredData, faqStructuredData, breadcrumbSchema]}
  noindex={isLimitedVariant}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>{title}</h1>
      <p style="color: var(--color-text-light); margin-bottom: 0.5rem;">
        {unsupportedReason ? from + ' to ' + to + ' conversion is not available in the current tool.' : 'Convert ' + from + ' images to ' + to + ' in your browser without uploading the image file.'}
      </p>
      <div class="privacy-badge">Image processing stays on this device</div>

      {(unsupportedReason || browserDependentNote) && (
        <div class={'status ' + (unsupportedReason ? 'status-error' : '')} style="margin-top: 1rem;">
          <strong>{unsupportedReason ? 'Not currently supported.' : 'Browser-dependent input.'}</strong>
          {' '}{unsupportedReason || browserDependentNote}
        </div>
      )}

      {!unsupportedReason && (
        <div style="margin-top: 1.5rem;">
          <ImageConverter client:load defaultFrom={from} defaultTo={to} />
        </div>
      )}

      {!unsupportedReason && <section class="howto-section">
        <h2>How to Convert {from} to {to}</h2>
        <ol class="howto-steps">
          <li>Upload your {from} file by dragging & dropping or clicking to browse</li>
          <li>Select {to} as the output format</li>
          {to !== 'PNG' && <li>Adjust the quality slider if needed</li>}
          <li>Click "Convert" and download your {to} file</li>
        </ol>
      </section>}

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>{unsupportedReason ? from + ' input or ' + to + ' output requires a future implementation' : from + ' to ' + to + ' conversion using the browser decoder'}</li>
          {!unsupportedReason && <li>Batch convert multiple files</li>}
          {!unsupportedReason && <li>Image pixels are processed locally - no file upload</li>}
          {!unsupportedReason && <li>Capacity depends on browser memory and canvas limits</li>}
          <li>Free with no watermarks</li>
          <li>Works on any device</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {faq.map((item: { question: string; answer: string }) => (
          <div class="faq-item">
            <details>
              <summary class="faq-question">{item.question}</summary>
              <div class="faq-answer">{item.answer}</div>
            </details>
          </div>
        ))}
      </section>

      <section class="related-tools">
        <h2>More Conversion Tools</h2>
        <div class="related-tools-grid">
          {allVariants.filter(v => v.slug !== slug).map(v => (
            <a href={`/tools/image-converter/${v.slug}`} class="tool-card"><h3>{v.from} to {v.to}</h3></a>
          ))}
        </div>
      </section>
    </div>

    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <div style="margin-top: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">All Conversions</h3>
        <ul style="font-size: 0.875rem; list-style: none;">
          {allVariants.map(v => (
            <li style="padding: 0.25rem 0;"><a href={`/tools/image-converter/${v.slug}`}>{v.from} → {v.to}</a></li>
          ))}
        </ul>
      </div>
      <div style="margin-top: 1.5rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">More Tools</h3>
        <ul style="font-size: 0.875rem; list-style: none;">
          <li style="padding: 0.25rem 0;"><a href="/tools/image-compressor">Image Compressor</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-resizer">Image Resizer</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-cropper">Image Cropper</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-to-pdf">Image to PDF</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/favicon-generator">Favicon Generator</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/background-remover">Background Remover</a></li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>
