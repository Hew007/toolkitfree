---
import Layout from '../../../layouts/Layout.astro';
import ToolDirectory from '../../../components/ToolDirectory.astro';
import FaviconGenerator from '../../../components/FaviconGenerator';
import { allVariants, variantData } from '../../../data/favicon-variants';

export function getStaticPaths() {
  return allVariants.map((v) => ({
    params: { variant: v.slug },
    props: { slug: v.slug, ...variantData[v.slug] },
  }));
}

const { title, description, faq, slug } = Astro.props;

const pageUrl = `https://toolkitfree.net/tools/favicon-generator/${Astro.params.variant}`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  description: description,
  url: pageUrl,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toolkitfree.net' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Favicon Generator',
      item: 'https://toolkitfree.net/tools/favicon-generator',
    },
    { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
  ],
};

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={pageUrl}
  structuredData={[structuredData, faqStructuredData, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>{title}</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        {description}
      </p>

      <div class="privacy-badge">
        <span style="color: #10b981; font-weight: 600;">Your files never leave your device</span>
      </div>

      <FaviconGenerator client:load />

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>All standard favicon sizes included</li>
          <li>site.webmanifest file generated</li>
          <li>HTML code snippet for easy integration</li>
          <li>High-quality image scaling</li>
          <li>100% client-side processing</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {
          faq.map((item: { question: string; answer: string }) => (
            <div class="faq-item">
              <details>
                <summary class="faq-question">{item.question}</summary>
                <div class="faq-answer">{item.answer}</div>
              </details>
            </div>
          ))
        }
      </section>

      <section class="related-tools">
        <h2>More Favicon Tools</h2>
        <div class="related-tools-grid">
          {
            allVariants
              .filter((v) => v.slug !== slug)
              .map((v) => (
                <a href={`/tools/favicon-generator/${v.slug}`} class="tool-card">
                  <h3>{v.label}</h3>
                </a>
              ))
          }
        </div>
      </section>
    </div>

    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <ToolDirectory currentId="favicon-generator" mode="sidebar" />
    </aside>
  </div>
</Layout>
