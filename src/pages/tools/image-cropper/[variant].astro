---
import Layout from '../../../layouts/Layout.astro';
import ImageCropper from '../../../components/ImageCropper';
import { allVariants, variantData } from '../../../data/cropper-variants';

export function getStaticPaths() {
  return allVariants.map((v) => ({
    params: { variant: v.slug },
    props: {
      slug: v.slug,
      ...variantData[v.slug],
    },
  }));
}

const { title, description, defaultAspectRatio, faq, slug } = Astro.props;

const pageUrl = `https://toolkitfree.net/tools/image-cropper/${Astro.params.variant}/`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolkitfree.net" },
    { "@type": "ListItem", "position": 2, "name": "Image Cropper", "item": "https://toolkitfree.net/tools/image-cropper" },
    { "@type": "ListItem", "position": 3, "name": title, "item": pageUrl },
  ]
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question", "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer },
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={pageUrl}
  structuredData={[structuredData, faqStructuredData, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>{title}</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        {description}
      </p>

      <div class="privacy-badge">
        <span style="color: #10b981; font-weight: 600;">Your files never leave your device</span>
      </div>

      <ImageCropper client:load defaultAspectRatio={defaultAspectRatio} />

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>Visual drag-and-drop crop area</li>
          <li>Rule-of-thirds grid overlay</li>
          <li>Output as PNG, JPG, or WebP</li>
          <li>Adjustable quality for JPG/WebP</li>
          <li>100% client-side processing</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {faq.map((item: { question: string; answer: string }) => (
          <div class="faq-item">
            <details>
              <summary class="faq-question">{item.question}</summary>
              <div class="faq-answer">{item.answer}</div>
            </details>
          </div>
        ))}
      </section>

      <section class="related-tools">
        <h2>More Crop Tools</h2>
        <div class="related-tools-grid">
          {allVariants.filter(v => v.slug !== slug).map(v => (
            <a href={`/tools/image-cropper/${v.slug}`} class="tool-card"><h3>{v.label}</h3></a>
          ))}
        </div>
      </section>
    </div>

    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <div style="margin-top: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">More Tools</h3>
        <ul style="font-size: 0.875rem; list-style: none;">
          <li style="padding: 0.25rem 0;"><a href="/tools/image-resizer/">Image Resizer</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-converter/">Image Converter</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-compressor/">Image Compressor</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-to-pdf/">Image to PDF</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/favicon-generator/">Favicon Generator</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/background-remover/">Background Remover</a></li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>
