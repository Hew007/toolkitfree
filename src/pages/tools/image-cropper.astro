---
import Layout from '../../layouts/Layout.astro';
import ImageCropper from '../../components/ImageCropper';

const faqItems = [
  {
    question: 'How do I crop an image?',
    answer: 'Upload your image, choose an aspect ratio or leave it as "Free," drag the crop handles to select the area you want to keep, and click Crop. Your cropped image is ready to download.',
  },
  {
    question: 'Is this image cropper free?',
    answer: 'Yes, ToolkitFree Image Cropper is completely free with no limits on usage. No sign-up, no watermark, no hidden fees.',
  },
  {
    question: 'Are my images uploaded to a server?',
    answer: 'No. All processing happens entirely in your browser using the Canvas API. Your images never leave your device.',
  },
  {
    question: 'What aspect ratios are supported?',
    answer: 'We support Free (any ratio), 1:1 (square), 16:9 (widescreen), 4:3 (standard), 3:2 (photography), and 9:16 (vertical/portrait).',
  },
  {
    question: 'What output formats are supported?',
    answer: 'You can save your cropped image as PNG (lossless), JPG (smaller file), or WebP (best compression). For JPG and WebP, you can adjust the quality.',
  },
  {
    question: 'Can I crop multiple images at once?',
    answer: 'Currently the tool processes one image at a time for the best visual control. Upload and crop each image individually.',
  },
  {
    question: 'How is cropping different from resizing?',
    answer: 'Cropping removes parts of the image, keeping only the selected area. Resizing changes the overall dimensions of the entire image without removing any content.',
  },
  {
    question: 'Can I crop a photo for Instagram?',
    answer: 'Yes! Select the 1:1 ratio for Instagram posts or 9:16 for Instagram Stories and Reels. The crop area is perfectly sized for these formats.',
  },
  {
    question: 'Will cropping reduce the quality of my image?',
    answer: 'No. Cropping only removes pixels outside the selection. The remaining pixels keep their original quality. To save as JPG or WebP, use high quality settings for best results.',
  },
  {
    question: 'Can I undo a crop?',
    answer: 'If you haven\'t closed the page, you can re-upload the original image and crop again. We recommend keeping your original file until you\'re satisfied with the result.',
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free Image Cropper",
  "description": "Crop images online with a visual crop tool. Supports free crop, square, 16:9, 4:3, 3:2 ratios. 100% client-side, no upload needed.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolkitfree.net" },
    { "@type": "ListItem", "position": 2, "name": "Image Cropper", "item": "https://toolkitfree.net/tools/image-cropper" },
  ]
};
---

<Layout
  title="Free Image Cropper — Crop Photos Online | ToolkitFree"
  description="Crop images online with a visual crop tool. Supports free crop, square (1:1), 16:9, 4:3, 3:2 aspect ratios. Drag to select crop area. Free, no upload needed."
  structuredData={[structuredData, {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question", "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer },
    })),
  }, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>Free Online Image Cropper</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Crop images to any size with a visual drag-and-drop tool.
        Supports square, 16:9, 4:3, 3:2, and free aspect ratios.
        All processing in your browser.
      </p>

      <div class="privacy-badge">
        <span style="color: #10b981; font-weight: 600;">Your files never leave your device</span>
      </div>

      <ImageCropper client:load />

      <section class="howto-section">
        <h2>How to Crop an Image</h2>
        <ol class="howto-steps">
          <li>Upload your image</li>
          <li>Choose an aspect ratio (Free, 1:1, 16:9, 4:3, 3:2, 9:16)</li>
          <li>Drag the crop handles to select the area you want to keep</li>
          <li>Choose output format and click "Crop Image"</li>
          <li>Download your cropped image</li>
        </ol>
      </section>

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>Visual drag-and-drop crop area</li>
          <li>Aspect ratio presets: 1:1, 16:9, 4:3, 3:2, 9:16, Free</li>
          <li>Rule-of-thirds grid overlay</li>
          <li>Resize handles on all edges and corners</li>
          <li>Output as PNG, JPG, or WebP</li>
          <li>Adjustable quality for JPG/WebP</li>
          <li>100% client-side — your images never leave your device</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {faqItems.map((item) => (
          <div class="faq-item">
            <details>
              <summary class="faq-question">{item.question}</summary>
              <div class="faq-answer">{item.answer}</div>
            </details>
          </div>
        ))}
      </section>

      <section class="related-tools">
        <h2>Related Tools</h2>
        <div class="related-tools-grid">
          <a href="/tools/image-resizer/" class="tool-card"><h3>Image Resizer</h3><p>Resize images to exact dimensions</p></a>
          <a href="/tools/image-converter/" class="tool-card"><h3>Image Converter</h3><p>Convert between JPG, PNG, and WebP</p></a>
          <a href="/tools/image-compressor/" class="tool-card"><h3>Image Compressor</h3><p>Reduce image file size</p></a>
          <a href="/tools/image-to-pdf/" class="tool-card"><h3>Image to PDF</h3><p>Convert images to PDF documents</p></a>
          <a href="/tools/background-remover/" class="tool-card"><h3>Background Remover</h3><p>Remove backgrounds using AI</p></a>
          <a href="/tools/qr-generator/" class="tool-card"><h3>QR Code Generator</h3><p>Create QR codes for URLs, WiFi, vCards, and more</p></a>
          <a href="/tools/image-enhancer/" class="tool-card"><h3>Image Enhancer</h3><p>Adjust brightness, contrast, sharpness, and more</p></a>
        </div>
      </section>
    </div>
    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <div style="margin-top: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">More Tools</h3>
        <ul style="font-size: 0.875rem; list-style: none;">
          <li style="padding: 0.25rem 0;"><a href="/tools/image-converter/">Image Converter</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-compressor/">Image Compressor</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-resizer/">Image Resizer</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-to-pdf/">Image to PDF</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/favicon-generator/">Favicon Generator</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/background-remover/">Background Remover</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/qr-generator/">QR Code Generator</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-enhancer/">Image Enhancer</a></li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>
