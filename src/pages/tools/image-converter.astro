---
import Layout from '../../layouts/Layout.astro';
import ToolDirectory from '../../components/ToolDirectory.astro';
import ImageConverter from '../../components/ImageConverter';

const faqItems = [
  {
    question: 'How does the image converter work?',
    answer:
      'Our image converter runs entirely in your browser using the Canvas API. When you upload an image, it is loaded into a hidden canvas element, then re-exported in your chosen format. Your files never leave your device.',
  },
  {
    question: 'What image formats are supported?',
    answer:
      'We support JPG/JPEG, PNG, and WebP formats for both input and output. You can convert between any of these formats. More formats like AVIF and HEIC may be added in future updates.',
  },
  {
    question: 'Is there a file size limit?',
    answer:
      'There is no server upload limit, but browser memory and Canvas dimension limits still apply. Large images or batches can be slow or fail, especially on mobile devices.',
  },
  {
    question: 'Can I convert multiple images at once?',
    answer:
      'Yes! You can upload and convert multiple images simultaneously. All conversions happen in parallel for maximum speed.',
  },
  {
    question: 'How do I download a converted batch?',
    answer:
      'Each successful result has its own download link. You can also choose Download all as ZIP to create one archive in your browser. Failed files are listed with their reason and are not added to the ZIP.',
  },
  {
    question: 'Will I lose image quality when converting?',
    answer:
      'PNG output uses lossless encoding for the decoded pixels, but conversion cannot restore detail already lost in the source. JPG and WebP are re-encoded and may lose quality; use the slider to control the tradeoff.',
  },
  {
    question: 'Is this tool free?',
    answer:
      'Yes, this tool is completely free to use with no limits. We support the site through non-intrusive ads.',
  },
  {
    question: 'Do you keep a copy of my images?',
    answer:
      'No. All processing happens in your browser. Your images are never uploaded to any server. When you close the page, all data is gone.',
  },
  {
    question: 'Can I use this on my phone?',
    answer:
      'Yes! Our image converter works on any device with a modern browser, including smartphones and tablets.',
  },
  {
    question: 'What is WebP and why should I use it?',
    answer:
      'WebP is a modern image format developed by Google that provides superior lossless and lossy compression for images on the web. WebP images are typically 25-34% smaller than comparable JPEG or PNG images.',
  },
  {
    question: 'How do I convert JPG to PNG?',
    answer:
      'Upload your JPG file, select PNG as the output format, and click Convert. The tool decodes the JPG and exports its pixels as PNG. PNG output avoids further lossy encoding, but it cannot restore detail already lost to JPG compression.',
  },
  {
    question: 'How do I convert PNG to JPG?',
    answer:
      'Upload your PNG file, select JPG as the output format, and click Convert. Note that JPG does not support transparency — transparent areas will be filled with white. You can also adjust the quality slider.',
  },
  {
    question: 'How do I convert images to WebP?',
    answer:
      'Upload any image file (JPG, PNG, etc.), select WebP as the output format, choose your quality level, and click Convert. WebP offers excellent compression while maintaining visual quality.',
  },
  {
    question: 'How do I change a picture from JPG to PNG?',
    answer:
      'Simply drag your JPG file onto the converter, select PNG from the output format dropdown, and click Convert. Your PNG will use lossless encoding for the decoded pixels, while existing JPG artifacts remain.',
  },
  {
    question: 'What is the best free image converter online?',
    answer:
      "ToolkitFree's image converter runs entirely in your browser — no uploads, no sign-ups, no watermarks. It supports JPG, PNG, and WebP with batch conversion and adjustable quality.",
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Free Image Converter',
  url: 'https://toolkitfree.net/tools/image-converter',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0' },
  description:
    'Convert images between JPG, PNG, and WebP formats instantly in your browser. Free, no upload needed.',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toolkitfree.net' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Image Converter',
      item: 'https://toolkitfree.net/tools/image-converter',
    },
  ],
};

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  title="Free Image Converter - Convert JPG, PNG, WebP Online | Batch, No Upload"
  description="Convert images between JPG, PNG, and WebP formats instantly in your browser. Batch convert multiple files. No upload needed. 100% free and private."
  structuredData={[structuredData, faqStructuredData, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>Free Online Image Converter</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Convert images between JPG, PNG, and WebP formats instantly. Batch support. No upload needed
        — your files stay on your device.
      </p>

      <ImageConverter client:load />

      <section class="howto-section">
        <h2>How to Convert Images</h2>
        <ol class="howto-steps">
          <li>Upload one or more images by dragging & dropping or clicking to browse</li>
          <li>Select your desired output format (JPG, PNG, or WebP)</li>
          <li>Adjust the quality slider if using JPG or WebP output</li>
          <li>Click "Convert", then download files individually or once as a ZIP</li>
        </ol>
      </section>

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>Convert between JPG, PNG, and WebP</li>
          <li>Batch convert multiple images with one ZIP download</li>
          <li>Adjustable quality for JPG and WebP</li>
          <li>100% client-side — no uploads required</li>
          <li>Capacity depends on browser memory and Canvas limits</li>
          <li>Free with no watermarks</li>
        </ul>
      </section>

      <!-- Ad Placeholder -->
      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {
          faqItems.map((item) => (
            <div class="faq-item">
              <details>
                <summary class="faq-question">{item.question}</summary>
                <div class="faq-answer">{item.answer}</div>
              </details>
            </div>
          ))
        }
      </section>

      <ToolDirectory currentId="image-converter" mode="related" />
    </div>

    <aside class="tool-sidebar">
      <!-- Ad Placeholder: Sidebar -->
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>

      <div style="margin-top: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">Supported Formats</h3>
        <ul style="font-size: 0.875rem; color: var(--color-text-light); list-style: none;">
          <li style="padding: 0.25rem 0;">JPG / JPEG</li>
          <li style="padding: 0.25rem 0;">PNG</li>
          <li style="padding: 0.25rem 0;">WebP</li>
        </ul>
      </div>

      <ToolDirectory currentId="image-converter" mode="sidebar" />
    </aside>
  </div>
</Layout>
