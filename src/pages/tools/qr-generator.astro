---
import Layout from '../../layouts/Layout.astro';
import QrGenerator from '../../components/QrGenerator';

const faqItems = [
  {
    question: 'What is a QR code?',
    answer: 'A QR code (Quick Response code) is a two-dimensional barcode that can store text, URLs, contact information, WiFi credentials, and more. You can scan it with any smartphone camera to access the encoded data instantly.',
  },
  {
    question: 'How do I create a QR code for free?',
    answer: 'Simply select the type of content you want to encode (text, URL, WiFi, vCard, etc.), fill in the details, and the QR code is generated instantly in your browser. Download it as PNG or SVG — completely free, no sign-up required.',
  },
  {
    question: 'Can I add my logo to the QR code?',
    answer: 'Yes! Upload any image as a logo and it will be placed in the center of the QR code. The error correction level is automatically set to High (H) to ensure the code remains scannable even with the logo overlay.',
  },
  {
    question: 'What error correction level should I use?',
    answer: 'For basic QR codes, Medium (M) is a good default. If you are adding a logo, use High (H). Higher error correction means the code can sustain more damage or obstruction while remaining scannable, but it also makes the code denser.',
  },
  {
    question: 'What is the difference between PNG and SVG QR codes?',
    answer: 'PNG is a raster image format — great for digital use and social media. SVG is a vector format that scales infinitely without losing quality — ideal for print materials, business cards, and large banners.',
  },
  {
    question: 'How do I create a WiFi QR code?',
    answer: 'Select the "WiFi" tab, enter your network name (SSID), security type (WPA/WEP/None), and password. When someone scans the code, their device will automatically connect to your WiFi network.',
  },
  {
    question: 'Can I make a QR code for a vCard?',
    answer: 'Yes. Select the "vCard" tab and fill in the contact details (name, phone, email, company, etc.). Scanning the code will let others save your contact information directly to their phone.',
  },
  {
    question: 'Are QR codes generated here sent to a server?',
    answer: 'No. All QR code generation happens entirely in your browser. No data is ever sent to any server. Your information stays completely private on your device.',
  },
  {
    question: 'Do QR codes expire?',
    answer: 'No, QR codes do not expire. Static QR codes like the ones generated here contain the data directly in the code itself. They will work forever as long as the encoded content (like a URL) is still valid.',
  },
  {
    question: 'Can I change the QR code colors?',
    answer: 'Yes. You can customize both the foreground (dot) color and the background color. For best scannability, maintain high contrast between the two colors. Dark dots on a light background work best.',
  },
  {
    question: 'How do I test if my QR code works?',
    answer: 'Open your phone camera app and point it at the QR code preview. Most modern smartphones (iPhone and Android) have built-in QR code scanning in the camera app.',
  },
  {
    question: 'What is the best error correction level for printing?',
    answer: 'For printed materials, use High (H) error correction. Printed QR codes may get scratched, smudged, or partially covered. Higher error correction ensures they remain scannable even with some damage.',
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free QR Code Generator",
  "description": "Generate QR codes for text, URLs, WiFi, vCards, email, phone, and SMS. Add logos, customize colors and dot styles. Download as PNG or SVG. 100% client-side.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolkitfree.net" },
    { "@type": "ListItem", "position": 2, "name": "QR Code Generator", "item": "https://toolkitfree.net/tools/qr-generator" },
  ]
};
---

<Layout
  title="Free QR Code Generator - Create QR Codes for URL, WiFi, vCard"
  description="Generate QR codes for text, URLs, WiFi networks, vCards, email, phone, and SMS. Add logos, customize colors. Download as PNG or SVG. 100% free, runs in your browser."
  structuredData={[structuredData, {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question", "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer },
    })),
  }, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>Free QR Code Generator</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Create QR codes for URLs, WiFi, vCards, email, phone, and SMS.
        Add your logo, customize colors and dot styles. 100% client-side — your data never leaves your device.
      </p>

      <QrGenerator client:load />

      <section class="howto-section">
        <h2>How to Create a QR Code</h2>
        <ol class="howto-steps">
          <li>Select the content type (Text, URL, WiFi, vCard, Email, Phone, or SMS)</li>
          <li>Fill in the details for your chosen type</li>
          <li>Customize colors, dot style, and optionally add a logo</li>
          <li>Download your QR code as PNG or SVG</li>
        </ol>
      </section>

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>6 QR code types: Text, URL, WiFi, vCard, Email, Phone, SMS</li>
          <li>Add your logo to the center of the QR code</li>
          <li>Custom foreground and background colors</li>
          <li>5 dot styles: Square, Rounded, Dots, Classy, Extra Round</li>
          <li>Download as PNG or SVG</li>
          <li>4 error correction levels for reliability</li>
          <li>100% client-side — no data uploaded</li>
          <li>Free with no limits or sign-up</li>
        </ul>
      </section>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {faqItems.map((item) => (
          <div class="faq-item">
            <details>
              <summary class="faq-question">{item.question}</summary>
              <div class="faq-answer">{item.answer}</div>
            </details>
          </div>
        ))}
      </section>

      <section class="related-tools">
        <h2>Related Tools</h2>
        <div class="related-tools-grid">
          <a href="/tools/image-converter" class="tool-card"><h3>Image Converter</h3><p>Convert between JPG, PNG, and WebP</p></a>
          <a href="/tools/image-compressor" class="tool-card"><h3>Image Compressor</h3><p>Reduce image file size</p></a>
          <a href="/tools/image-resizer" class="tool-card"><h3>Image Resizer</h3><p>Resize images to any dimension</p></a>
          <a href="/tools/background-remover" class="tool-card"><h3>Background Remover</h3><p>Remove image backgrounds with AI</p></a>
        </div>
      </section>
    </div>
    <aside class="tool-sidebar">
      <div style="margin-bottom: 1.5rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">Supported QR Types</h3>
        <ul style="font-size: 0.875rem; list-style: none; color: var(--color-text-light);">
          <li style="padding: 0.25rem 0;">Text / URL</li>
          <li style="padding: 0.25rem 0;">WiFi Network</li>
          <li style="padding: 0.25rem 0;">vCard Contact</li>
          <li style="padding: 0.25rem 0;">Email</li>
          <li style="padding: 0.25rem 0;">Phone Number</li>
          <li style="padding: 0.25rem 0;">SMS Message</li>
        </ul>
      </div>
      <div style="margin-top: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">More Tools</h3>
        <ul style="font-size: 0.875rem; list-style: none;">
          <li style="padding: 0.25rem 0;"><a href="/tools/image-converter">Image Converter</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-compressor">Image Compressor</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-resizer">Image Resizer</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/background-remover">Background Remover</a></li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>
