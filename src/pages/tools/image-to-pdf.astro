---
import Layout from '../../layouts/Layout.astro';
import ImageToPdf from '../../components/ImageToPdf';

const faqItems = [
  {
    question: 'How do I convert images to PDF?',
    answer: 'Upload one or more images, choose page size (A4, Letter, or fit to image), set orientation and margins, then click "Convert to PDF." Your PDF is ready to download.',
  },
  {
    question: 'Is this image to PDF converter free?',
    answer: 'Yes, completely free. No sign-up, no watermarks, no file size limits. All processing happens in your browser.',
  },
  {
    question: 'Are my images uploaded to a server?',
    answer: 'No. All PDF generation happens entirely in your browser using the jsPDF library. Your images never leave your device.',
  },
  {
    question: 'Can I combine multiple images into one PDF?',
    answer: 'Yes. Upload multiple images and they will be combined into a single multi-page PDF, with each image on its own page.',
  },
  {
    question: 'What page sizes are supported?',
    answer: 'We support A4 (210×297mm), US Letter (8.5×11"), and "Fit to Image" which creates a page matching each image\'s exact dimensions.',
  },
  {
    question: 'What image formats can I convert?',
    answer: 'Any format your browser can open: JPG, PNG, WebP, GIF, BMP, TIFF, and more. All images are converted to high-quality JPEG pages in the PDF.',
  },
  {
    question: 'Can I adjust margins?',
    answer: 'Yes. You can set margins from 0mm to 30mm. Set to 0 or choose "Fit to Image" for edge-to-edge images.',
  },
  {
    question: 'How is this different from other online converters?',
    answer: 'ToolkitFree processes everything locally in your browser. No uploads, no waiting for server processing, no privacy concerns. It works offline once loaded.',
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free Image to PDF Converter",
  "description": "Convert images to PDF online. Supports JPG, PNG, WebP. Combine multiple images into one PDF. A4, Letter, custom page sizes. 100% client-side.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolkitfree.net" },
    { "@type": "ListItem", "position": 2, "name": "Image to PDF", "item": "https://toolkitfree.net/tools/image-to-pdf" },
  ]
};
---

<Layout
  title="Image to PDF — Convert Images Online Free | ToolkitFree"
  description="Convert images to PDF online. Supports JPG, PNG, WebP. Combine multiple images into one PDF. A4, Letter, or fit-to-image page sizes. Free, no upload needed."
  structuredData={[structuredData, {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question", "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer },
    })),
  }, breadcrumbSchema]}
>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>Free Online Image to PDF Converter</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Convert images to PDF. Supports JPG, PNG, WebP, and more.
        Combine multiple images into one PDF. A4, Letter, or fit-to-image.
        All processing in your browser.
      </p>

      <div class="privacy-badge">
        <span style="color: #10b981; font-weight: 600;">Your files never leave your device</span>
      </div>

      <ImageToPdf client:load />

      <section class="howto-section">
        <h2>How to Convert Images to PDF</h2>
        <ol class="howto-steps">
          <li>Upload one or more images</li>
          <li>Choose page size (A4, Letter, or Fit to Image)</li>
          <li>Set orientation and margins</li>
          <li>Click "Convert to PDF"</li>
          <li>Download your PDF</li>
        </ol>
      </section>

      <section class="features-section">
        <h2>Features</h2>
        <ul class="features-list">
          <li>Combine multiple images into one PDF</li>
          <li>A4 and US Letter page sizes</li>
          <li>Fit-to-image mode for exact dimensions</li>
          <li>Portrait and landscape orientation</li>
          <li>Adjustable margins (0-30mm)</li>
          <li>Supports JPG, PNG, WebP, GIF, BMP, and more</li>
          <li>100% client-side — your images never leave your device</li>
        </ul>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {faqItems.map((item) => (
          <div class="faq-item">
            <details>
              <summary class="faq-question">{item.question}</summary>
              <div class="faq-answer">{item.answer}</div>
            </details>
          </div>
        ))}
      </section>

      <section class="related-tools">
        <h2>Related Tools</h2>
        <div class="related-tools-grid">
          <a href="/tools/image-converter" class="tool-card"><h3>Image Converter</h3><p>Convert between JPG, PNG, and WebP</p></a>
          <a href="/tools/image-compressor" class="tool-card"><h3>Image Compressor</h3><p>Reduce image file size</p></a>
          <a href="/tools/image-cropper" class="tool-card"><h3>Image Cropper</h3><p>Crop images with visual drag-and-drop</p></a>
          <a href="/tools/image-resizer" class="tool-card"><h3>Image Resizer</h3><p>Resize images to any dimension</p></a>
        </div>
      </section>
    </div>
    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <div style="margin-top: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">More Tools</h3>
        <ul style="font-size: 0.875rem; list-style: none;">
          <li style="padding: 0.25rem 0;"><a href="/tools/image-converter">Image Converter</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-compressor">Image Compressor</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-resizer">Image Resizer</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-cropper">Image Cropper</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/favicon-generator">Favicon Generator</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/background-remover">Background Remover</a></li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>
