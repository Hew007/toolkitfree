---
import Layout from '../../layouts/Layout.astro';
import PdfPageExtractor from '../../components/PdfPageExtractor';
import ToolDirectory from '../../components/ToolDirectory.astro';
import { toPublicUrl } from '../../data/tool-registry';

const title = 'PDF Splitter & Page Extractor — Free Local Tool';
const description =
  'Split a PDF, extract selected pages, reorder, rotate, or remove pages locally in your browser. Export one combined PDF or separate page PDFs in a ZIP.';
const canonical = toPublicUrl('/tools/pdf-splitter');
const faqItems = [
  {
    question: 'How do I extract specific pages from a PDF?',
    answer:
      'Choose a PDF, enter page numbers or ranges such as 1-3, 5, 8-10, and apply the selection. You can reorder or rotate those pages before exporting them into one new PDF.',
  },
  {
    question: 'Can I split every PDF page into a separate file?',
    answer:
      'Yes. Select the pages you want, choose the separate-pages option, and the tool creates one PDF per selected page inside a ZIP download.',
  },
  {
    question: 'Is my PDF uploaded?',
    answer:
      'No. The PDF is read, previewed, edited, and exported in your browser. The page loads its PDF processing libraries from this site, but your document content is not uploaded for processing.',
  },
  {
    question: 'Will links, text, and image quality be preserved?',
    answer:
      'Pages are copied from the source PDF instead of being converted into screenshots, so page content and quality are normally preserved. Document-level features, forms, signatures, bookmarks, or cross-page links may not carry into a newly extracted PDF.',
  },
  {
    question: 'Can I open a password-protected PDF?',
    answer:
      'Password-protected or encrypted PDFs are not supported in the first version. Remove the password with an authorized PDF application before using this tool.',
  },
  {
    question: 'What limits apply?',
    answer:
      'Desktop devices can open PDFs up to 100 MiB and 300 pages. Mobile devices are limited to 50 MiB and 150 pages to reduce browser memory pressure.',
  },
];
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'PDF Splitter & Page Extractor',
    description,
    url: canonical,
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    featureList: [
      'Extract selected PDF pages',
      'Split pages into individual PDF files',
      'Reorder, rotate, and remove pages',
      'Local browser processing',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: toPublicUrl('/') },
      { '@type': 'ListItem', position: 2, name: 'PDF Splitter', item: canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical} structuredData={schemas}>
  <div class="tool-layout">
    <div class="tool-content">
      <h1>PDF Splitter & Page Extractor</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1rem;">
        Select, reorder, rotate, remove, and export PDF pages without uploading your document.
      </p>
      <div class="privacy-badge">
        Your PDF stays on this device · processing libraries load only when you choose a file
      </div>

      <PdfPageExtractor client:load />

      <section class="howto-section">
        <h2>How to Split or Extract PDF Pages</h2>
        <ol class="howto-steps">
          <li>Choose one PDF from your computer or mobile device.</li>
          <li>Select pages individually or enter a range such as 1-3, 5, 8-10.</li>
          <li>Reorder, rotate, or remove pages if needed.</li>
          <li>Export selected pages into one PDF or split them into separate PDFs in a ZIP.</li>
          <li>Download the result directly from your browser.</li>
        </ol>
      </section>

      <section class="features-section">
        <h2>What This Tool Preserves</h2>
        <ul class="features-list">
          <li>Original PDF page content and resolution</li>
          <li>Original page dimensions</li>
          <li>Page order chosen in the editor</li>
          <li>Additional 90-degree page rotations</li>
          <li>No watermark or document upload</li>
          <li>One combined PDF or individual page files</li>
        </ul>
      </section>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {
          faqItems.map((item) => (
            <div class="faq-item">
              <details>
                <summary class="faq-question">{item.question}</summary>
                <div class="faq-answer">{item.answer}</div>
              </details>
            </div>
          ))
        }
      </section>

      <ToolDirectory currentId="pdf-splitter" mode="related" />
    </div>
    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <ToolDirectory currentId="pdf-splitter" mode="sidebar" />
    </aside>
  </div>
</Layout>
