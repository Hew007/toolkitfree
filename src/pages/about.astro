---
import Layout from '../layouts/Layout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About ToolkitFree",
  "description": "Free, privacy-first browser-based tools. Your files never leave your device.",
  "url": "https://toolkitfree.net/about/",
  "mainEntity": {
    "@type": "Organization",
    "name": "ToolkitFree",
    "url": "https://toolkitfree.net",
    "description": "Free, local-first processing tools that run entirely in your browser. No uploads, no accounts, no limits."
  }
};
---

<Layout
  title="About Us - Free, Privacy-First Browser Tools"
  description="ToolkitFree provides free tools that process your files entirely in your browser. No uploads, no accounts, no tracking. Your files never leave your device."
  canonical="https://toolkitfree.net/about/"
  structuredData={structuredData}
>
  <section class="hero">
    <h1>Your Browser Is the Only Tool You Need.</h1>
    <p>
      Free tools. Local processing. Zero compromise.
      Your files never leave your device — process locally, stay secure, use freely.
    </p>
    <div class="privacy-badge">
      Privacy-First by Design
    </div>
  </section>

  <section class="features-section">
    <h2>What We Do</h2>
    <p style="color: var(--color-text-light); line-height: 1.8;">
      ToolkitFree is a free, browser-based toolkit that processes your files entirely on your device.
      No uploads. No accounts. No limits. We believe powerful tools should be accessible to everyone,
      everywhere — without compromising your privacy. Every operation runs locally in your browser,
      so your files never leave your hands.
    </p>
    <p style="color: var(--color-text-light); line-height: 1.8; margin-top: 1rem;">
      Currently focused on image tools — converter, compressor, resizer, and background remover —
      with more categories on the way.
    </p>
  </section>

  <section class="features-section">
    <h2>Core Principles</h2>
    <ul class="features-list">
      <li>100% free, no sign-up required</li>
      <li>Your files never leave your device</li>
      <li>Local processing — no server uploads</li>
      <li>No file size limits</li>
      <li>No watermarks on output</li>
      <li>Works on any device with a browser</li>
    </ul>
  </section>

  <section class="features-section">
    <h2>How It Works</h2>
    <p style="color: var(--color-text-light); line-height: 1.8;">
      All ToolkitFree tools run entirely in your browser using modern web technologies
      including the Canvas API and WebAssembly. Your files are processed locally on your
      device — they are never uploaded to any server. This means complete privacy,
      no file size limits, and instant processing without waiting for server uploads.
    </p>
  </section>

  <section class="features-section">
    <h2>Our Tools</h2>
    <div class="related-tools-grid">
      <a href="/tools/image-converter/" class="tool-card">
        <h3>Image Converter</h3>
        <p>Convert between JPG, PNG, WebP, and more.</p>
      </a>
      <a href="/tools/image-compressor/" class="tool-card">
        <h3>Image Compressor</h3>
        <p>Reduce file size while maintaining quality.</p>
      </a>
      <a href="/tools/image-resizer/" class="tool-card">
        <h3>Image Resizer</h3>
        <p>Resize and crop images to exact dimensions.</p>
      </a>
      <a href="/tools/background-remover/" class="tool-card">
        <h3>Background Remover</h3>
        <p>Remove image backgrounds using AI.</p>
      </a>
    </div>
  </section>

  <section class="features-section">
    <h2>What's Next</h2>
    <p style="color: var(--color-text-light); line-height: 1.8;">
      We're just getting started. Our roadmap includes expanding beyond image tools into
      PDF processing, document conversion, and other everyday file utilities — all built
      with the same privacy-first, zero-cost philosophy. More languages and localized
      content are also planned to make these tools accessible to users worldwide.
    </p>
  </section>

  <section class="features-section">
    <h2>Privacy & Compliance</h2>
    <p style="color: var(--color-text-light); line-height: 1.8;">
      By design, ToolkitFree is compliant with major privacy regulations including the
      EU General Data Protection Regulation (GDPR) and the California Consumer Privacy Act (CCPA).
      Since all processing happens locally in your browser, we never collect, store, or process
      your personal files or data. There is nothing to delete because we never had it in the first place.
    </p>
    <p style="color: var(--color-text-light); line-height: 1.8; margin-top: 1rem;">
      For more details, see our <a href="/privacy-policy">Privacy Policy</a> and
      <a href="/terms">Terms of Service</a>.
    </p>
  </section>

  <section class="features-section" style="margin-bottom: 2rem;">
    <h2>Get in Touch</h2>
    <p style="color: var(--color-text-light); line-height: 1.8;">
      Have questions, feedback, or ideas? We'd love to hear from you.
      Reach out at <a href="mailto:hnhw182@gmail.com">hnhw182@gmail.com</a> or visit our
      <a href="/contact">Contact</a> page.
    </p>
  </section>
</Layout>
