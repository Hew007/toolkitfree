---
import Layout from '../../layouts/Layout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'How to Reduce Image File Size with Controlled Quality',
  description: 'Learn 5 ways to make images smaller while choosing an acceptable quality tradeoff.',
  url: 'https://toolkitfree.net/guides/reduce-image-size',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toolkitfree.net' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Reduce Image Size',
      item: 'https://toolkitfree.net/guides/reduce-image-size',
    },
  ],
};

const faqItems = [
  {
    question: 'How can I reduce image size without losing quality?',
    answer:
      'The best way is to convert to WebP format, which is 25-34% smaller than JPG at equivalent quality. If you need to keep the same format, compress at 85% quality — the difference is imperceptible.',
  },
  {
    question: 'Why is my image file so large?',
    answer:
      'Large images usually come from high-resolution cameras (20-50MP). A single photo can be 5-15MB. The resolution (pixel dimensions) is the biggest factor in file size.',
  },
  {
    question: 'What is the best free image compressor?',
    answer:
      'Our browser-based compressor processes images locally — no uploads needed. It supports JPG, PNG, and WebP with adjustable quality and batch compression. Try our Image Compressor tool.',
  },
];

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Layout
  title="How to Reduce Image File Size with Controlled Quality"
  description="5 ways to make images smaller while controlling quality. Compress, resize, convert to WebP, and optimize for web."
  structuredData={[structuredData, breadcrumbSchema, faqStructuredData]}
>
  <article class="tool-layout">
    <div class="tool-content">
      <h1>How to Reduce Image File Size with Controlled Quality</h1>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Large images slow down websites, fill up storage, and make sharing difficult. Here are 5
        proven methods to reduce image file size while keeping quality high.
      </p>

      <section class="howto-section">
        <h2>Method 1: Compress with Quality Control</h2>
        <p>
          The simplest method. Lower the JPEG quality from 100% to 80-85%. At this level, the
          quality difference is invisible to the eye, but file sizes drop by 40-60%.
        </p>
        <p><a href="/tools/image-compressor">Try Image Compressor</a></p>
      </section>

      <section class="howto-section">
        <h2>Method 2: Resize Dimensions</h2>
        <p>
          A 4000px wide photo on a website that only displays at 1200px is wasting bandwidth. Resize
          to the actual display size for massive savings. A 4000px photo resized to 1920px reduces
          file size by ~75%.
        </p>
        <p><a href="/tools/image-resizer">Try Image Resizer</a></p>
      </section>

      <section class="howto-section">
        <h2>Method 3: Convert to WebP</h2>
        <p>
          WebP is a modern format that's 25-34% smaller than JPG and PNG at equivalent quality.
          Converting your images to WebP is one of the easiest ways to reduce file size.
        </p>
        <p>
          <a href="/tools/image-converter/jpg-to-webp">Convert JPG to WebP</a> | <a
            href="/tools/image-converter/png-to-webp">Convert PNG to WebP</a
          >
        </p>
      </section>

      <section class="howto-section">
        <h2>Method 4: Choose the Right Format</h2>
        <p>
          PNG files are 3-10x larger than JPG for photos. If your image doesn't need transparency,
          convert from PNG to JPG. For graphics and logos, PNG or WebP lossless is best.
        </p>
        <p><a href="/tools/image-converter/png-to-jpg">Convert PNG to JPG</a></p>
      </section>

      <section class="howto-section">
        <h2>Method 5: Batch Process</h2>
        <p>
          Processing images one by one is slow. Use batch compression to optimize dozens of images
          at once. Set your preferred quality and max width once, then compress everything.
        </p>
        <p><a href="/tools/image-compressor">Batch Compress Images</a></p>
      </section>

      <div style="margin: 2rem 0;">
        <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
      </div>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {
          faqItems.map((item) => (
            <div class="faq-item">
              <details>
                <summary class="faq-question">{item.question}</summary>
                <div class="faq-answer">{item.answer}</div>
              </details>
            </div>
          ))
        }
      </section>
    </div>

    <aside class="tool-sidebar">
      <div class="ad-placeholder ad-sidebar">Ad Space (300x250)</div>
      <div style="margin-top: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">Quick Tools</h3>
        <ul style="font-size: 0.875rem; list-style: none;">
          <li style="padding: 0.25rem 0;">
            <a href="/tools/image-compressor">Image Compressor</a>
          </li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-resizer">Image Resizer</a></li>
          <li style="padding: 0.25rem 0;"><a href="/tools/image-converter">Image Converter</a></li>
        </ul>
      </div>
    </aside>
  </article>
</Layout>
