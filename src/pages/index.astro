---
import Layout from '../layouts/Layout.astro';
import { toPublicPath, toolRegistry } from '../data/tool-registry';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ToolkitFree',
  description:
    'Free online image tools. Convert, compress, resize, and edit images in your browser. No uploads needed.',
  url: 'https://toolkitfree.net',
};
---

<Layout
  title="Free Online Image Tools - Convert, Compress, Resize"
  description="Free online image tools. Convert formats, compress file size, resize dimensions, and remove backgrounds. All processing happens in your browser - your files never leave your device."
  structuredData={structuredData}
>
  <section class="hero">
    <h1>Free Online Image Tools</h1>
    <p>
      Convert, compress, resize, and edit images directly in your browser. No uploads needed — your
      files never leave your device.
    </p>
    <div class="privacy-badge">100% Client-Side Processing</div>
  </section>

  <section class="tools-grid">
    {
      toolRegistry.map((tool) => (
        <a href={toPublicPath(tool.href)} class="tool-card" data-tool-id={tool.id}>
          <h3>{tool.name}</h3>
          <p>{tool.description}</p>
        </a>
      ))
    }
  </section>

  <!-- Ad Placeholder: In-content -->
  <div style="margin: 3rem 0;">
    <div class="ad-placeholder ad-banner">Ad Space (728x90)</div>
  </div>

  <section class="features-section">
    <h2>Why ToolkitFree?</h2>
    <ul class="features-list">
      <li>100% free, no sign-up required</li>
      <li>Your files never leave your device</li>
      <li>No server upload limit; browser memory limits still apply</li>
      <li>Works on any device with a browser</li>
      <li>Batch support in converter, compressor, resizer, and image-to-PDF</li>
      <li>No watermarks on output</li>
    </ul>
  </section>

  <section class="features-section">
    <h2>How ToolkitFree Works</h2>
    <p style="color: var(--color-text-light);">
      All ToolkitFree tools run entirely in your browser using modern web technologies including the
      Canvas API and WebAssembly. Your images are processed locally on your device — they are never
      uploaded to any server. File contents stay local, but capacity depends on device memory and
      browser Canvas limits. The page still downloads site assets, advertising code, and, for
      background removal, model files.
    </p>
  </section>

  <section class="features-section">
    <h2>Who Is This For?</h2>
    <ul class="features-list">
      <li>Bloggers and content creators optimizing images for the web</li>
      <li>Social media managers resizing images for Instagram, Facebook, Twitter, YouTube</li>
      <li>E-commerce sellers preparing product photos</li>
      <li>Anyone who needs quick image edits without installing software</li>
    </ul>
  </section>

  <section class="features-section">
    <h2>Popular Tools</h2>
    <div class="related-tools-grid">
      <a href="/tools/image-converter/jpg-to-png/" class="tool-card"><h3>JPG to PNG</h3></a>
      <a href="/tools/image-converter/png-to-jpg/" class="tool-card"><h3>PNG to JPG</h3></a>
      <a href="/tools/image-converter/jpg-to-webp/" class="tool-card"><h3>JPG to WebP</h3></a>
      <a href="/tools/image-compressor/compress-for-web/" class="tool-card"
        ><h3>Compress for Web</h3></a
      >
      <a href="/tools/image-resizer/resize-for-instagram/" class="tool-card"
        ><h3>Resize for Instagram</h3></a
      >
      <a href="/tools/image-cropper/crop-to-square/" class="tool-card"><h3>Crop to Square</h3></a>
      <a href="/tools/image-to-pdf/jpg-to-pdf/" class="tool-card"><h3>JPG to PDF</h3></a>
      <a href="/tools/favicon-generator/png-to-favicon/" class="tool-card"
        ><h3>PNG to Favicon</h3></a
      >
      <a href="/tools/background-remover/" class="tool-card"><h3>Remove Background</h3></a>
    </div>
  </section>
</Layout>
