---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found"
  description="The page you are looking for does not exist. Browse our free online image tools."
>
  <section style="text-align: center; padding: 3rem 0;">
    <h1>Page Not Found</h1>
    <p style="color: var(--color-text-light); margin: 1rem 0 2rem;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="related-tools-grid">
      <a href="/tools/image-converter" class="tool-card"><h3>Image Converter</h3><p>Convert between JPG, PNG, and WebP</p></a>
      <a href="/tools/image-compressor" class="tool-card"><h3>Image Compressor</h3><p>Reduce image file size</p></a>
      <a href="/tools/image-resizer" class="tool-card"><h3>Image Resizer</h3><p>Resize images to any dimension</p></a>
      <a href="/tools/background-remover" class="tool-card"><h3>Background Remover</h3><p>Remove backgrounds using AI</p></a>
    </div>
  </section>
</Layout>
