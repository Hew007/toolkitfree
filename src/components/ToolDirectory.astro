---
import { getOtherTools, getRelatedTools, type ToolId } from '../data/tool-registry';

interface Props {
  currentId: ToolId;
  mode: 'related' | 'sidebar';
}

const { currentId, mode } = Astro.props;
const tools = mode === 'related' ? getRelatedTools(currentId) : getOtherTools(currentId);
---

{
  mode === 'related' ? (
    <section class="related-tools" data-tool-directory="related">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        {tools.map((tool) => (
          <a href={tool.href} class="tool-card" data-tool-id={tool.id}>
            <h3>{tool.name}</h3>
            <p>{tool.shortDescription}</p>
          </a>
        ))}
      </div>
    </section>
  ) : (
    <div style="margin-top: 2rem;" data-tool-directory="sidebar">
      <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">More Tools</h3>
      <ul style="font-size: 0.875rem; list-style: none;">
        {tools.map((tool) => (
          <li style="padding: 0.25rem 0;">
            <a href={tool.href} data-tool-id={tool.id}>
              {tool.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )
}
