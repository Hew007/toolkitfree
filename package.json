{
  "name": "toolkitfree",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "validate:processing": "node scripts/validate-image-processing.mjs",
    "validate:converter": "node scripts/validate-image-converter.mjs",
    "validate:compressor": "node scripts/validate-image-compressor.mjs",
    "validate:resizer-cropper": "node scripts/validate-resizer-cropper.mjs",
    "validate:secondary-tools": "node scripts/validate-secondary-tools.mjs",
    "validate:batch-download": "node scripts/validate-batch-download.mjs",
    "validate:batch-download:browser": "node scripts/validate-batch-download-browser.mjs",
    "validate:responsive-accessibility:browser": "node scripts/validate-responsive-accessibility-browser.mjs",
    "validate:performance": "node scripts/validate-performance-guards.mjs",
    "validate:performance:browser": "node scripts/validate-performance-browser.mjs",
    "sync:llms": "node scripts/sync-llms-registry.mjs",
    "validate:seo": "node scripts/validate-seo-registry.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro}\" \"scripts/*.mjs\" \"*.{json,mjs,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro}\" \"scripts/*.mjs\" \"*.{json,mjs,js}\"",
    "test": "node scripts/run-unit-tests.mjs",
    "test:e2e": "node scripts/run-browser-tests.mjs",
    "test:e2e:edge": "node scripts/run-browser-tests.mjs --browser=edge --smoke",
    "validate:site": "node scripts/validate-site-integrity.mjs",
    "check": "node scripts/run-quality-gates.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.7",
    "@imgly/background-removal": "^1.7.0",
    "astro": "^5.7.10",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "qr-code-styling": "^1.9.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1",
    "wrangler": "^4.93.0"
  }
}
